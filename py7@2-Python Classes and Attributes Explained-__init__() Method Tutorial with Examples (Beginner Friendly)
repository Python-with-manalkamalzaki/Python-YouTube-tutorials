# functions  __init__
# it is a dunder method or magic method
# dunder methods are preceded and proceeded with double underscores
# __init__ is a magic method called 'constructor'
# crucial for understanding python classes and objects
# __init__ method is automatically called on creating an instance of a class
# __init__ method  initializes the attributes (properties) of an object during object creation

# code 1
class Student:
    def __init__ (self,name, age):  # name & age are arguments
        self.name=name   # self points to the current instance
        self.age=age     # name & age associated with self are attributes

    def action(self):    # action method is added to the class
        print(f"The the student {self.name} goes to school every day")

student_1 = Student("Tom", 12)  # Tom & 12 are attributes
# when the instance (class object) student_1 is created, it automatically calls the __init__ method:
# self is passed to student_1 ie, it refers to the current instance
# the attributes Tom & 12 are passed to the arguments name & age
print(student_1.name)        # instance.attribute
print(student_1.age)         # instance.attribute
print(student_1.action())    # instance.method

