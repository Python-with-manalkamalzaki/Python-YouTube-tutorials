# code 3  classes - introduce attributes and methods
class Mammals:
    def __init__(self, name): # self refers to mammal_1
        self.name=name   # instance attribute

    def give_birth(self):  # instance method with argument self
        print(f" A {self.name} gives birth")

    def move(self, movement):  # instance method with 2 arguments
        print(f" A {self.name} can {movement}")

mammal_1=Mammals("dog") # create the class object
mammal_1.move("walk")   # instance.method
mammal_1.give_birth()   # instance.method

mammal_2=Mammals("bat") # create the class object
mammal_2.move("fly")
mammal_2.give_birth()

